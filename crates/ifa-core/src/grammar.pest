// ═══════════════════════════════════════════════════════════════════════════
// IFÁ-LANG GRAMMAR - PEST FORMAT
// ═══════════════════════════════════════════════════════════════════════════
// A program is a sequence of statements

program = { SOI ~ statement* ~ EOI }

// ═══════════════════════════════════════════════════════════════════════════
// STATEMENTS
// ═══════════════════════════════════════════════════════════════════════════

statement = {
    import_stmt
    | from_import_stmt
    | instruction
    | opon_stmt
    | ebo_stmt
    | ailewu_stmt
    | var_decl
    | const_stmt
    | update_stmt
    | assignment_stmt

    | odu_def
    | ese_def
    | if_stmt
    | while_stmt
    | for_stmt
    | return_stmt
    | taboo_stmt
    | ewo_stmt
    | ase_stmt
    | match_stmt
    | try_stmt
    | yield_stmt
    | COMMENT
}

// Import: iba std.otura;
import_stmt = { import_kw ~ module_path ~ ";" }

// Named Import: iba { yọkuro, pin } from std.otura;
from_import_stmt = { import_kw ~ "{" ~ ident ~ ("," ~ ident)* ~ "}" ~ from_kw ~ module_path ~ ";" }

module_path = { ident ~ ("." ~ ident)* }

// Opon (memory) directive: #opon kekere; or opon: nla;
opon_stmt = { opon_kw ~ ":"? ~ opon_size ~ ";"? }
opon_kw = { "#opon" | "opon" | "#Opon" | "Opon" | "#mem" | "mem" }
opon_size = {
    "kekere" | "kẹ́kẹ́rẹ́" | "small" | "tiny" | "embedded"
    | "arinrin" | "àrínrin" | "medium" | "standard" | "default"
    | "nla" | "nlá" | "large" | "big"
    | "ailopin" | "àìlópin" | "unlimited" | "dynamic" | "max"
}

// Ebo (offering/initiation): ebo "server"; or sacrifice config;
ebo_stmt = { ebo_kw ~ expression ~ ";"? }
ebo_kw = { "ebo" | "ẹbọ" | "sacrifice" }

// Variable: ayanmo x = 5;
var_decl = { public_mod? ~ var_kw ~ ident ~ type_hint? ~ "=" ~ expression ~ ";" }
type_hint = { ":" ~ type_name }
type_name = {
    "Int" | "Float" | "Str" | "Bool" | "List" | "Map" | "Any"
    | "int" | "float" | "str" | "bool" | "list" | "map" | "any"
    | "i8" | "i16" | "i32" | "i64"
    | "u8" | "u16" | "u32" | "u64"
    | "f32" | "f64"
    | "void"
}

// Constant: const X = 1;
const_stmt = { public_mod? ~ const_kw ~ ident ~ "=" ~ expression ~ ";" }
const_kw = { "const" | "loruko" | "ka" | "ayanfe" | "àyànfẹ́" }

// Assignment: x = 5; *p = 5; arr[0] = 5;
assignment_stmt = { lvalue ~ "=" ~ expression ~ ";" }

// Update: x += 5;
update_stmt = { lvalue ~ update_op ~ expression ~ ";" }
update_op = { "+=" | "-=" | "*=" | "/=" }

lvalue = { deref_lvalue | index_lvalue | property_access | ident }
deref_lvalue = { "*" ~ expression } // *ptr
index_lvalue = { ident ~ "?."? ~ "[" ~ expression ~ "]" }

// Instruction: Obara.fikun(10);
instruction = { (odu_call | method_call | function_call) ~ ";" }
// Domain call: Obara.fikun(10) or Obara?.fikun(10)
odu_call = { odu_name ~ chain_op ~ ident ~ "(" ~ arguments? ~ ")" }

// Class: odu Server { }
odu_def = { public_mod? ~ odu_kw ~ ident ~ "{" ~ odu_body ~ "}" }
odu_body = { (ese_def | var_decl)* }

// Function: ese start() { } or daro ese start() { }
ese_def = { public_mod? ~ async_mod? ~ ese_kw ~ ident ~ "(" ~ params? ~ ")" ~ "{" ~ statement* ~ "}" }
params = { param ~ ("," ~ param)* }
param = { ident ~ (":" ~ type_name)? }

// If statement
if_stmt = { if_kw ~ expression ~ "{" ~ statement* ~ "}" ~ else_clause? }
else_clause = { else_kw ~ "{" ~ statement* ~ "}" }

// While loop
while_stmt = { while_kw ~ expression ~ "{" ~ statement* ~ "}" }

// For loop: fun i ninu items { }
for_stmt = { for_kw ~ ident ~ in_kw ~ expression ~ "{" ~ statement* ~ "}" }

// Return
return_stmt = { return_kw ~ expression? ~ ";" }

// Taboo declaration: èèwọ̀: Ose -> Odi;
taboo_stmt = { taboo_kw ~ ":" ~ odu_name ~ "->" ~ odu_name ~ ";" }
taboo_kw = { "èèwọ̀" | "ewọ" | "taboo" }

// Assertion: ewo x > 0; or assert balance >= 0;
ewo_stmt = { ewo_kw ~ expression ~ ("," ~ string)? ~ ";" }
ewo_kw = { "ewo" | "ẹ̀wọ̀" | "assert" | "verify" }

// End: ase;
ase_stmt = { ase_kw ~ ";"? }

// Match statement
match_stmt = { match_kw ~ "(" ~ expression ~ ")" ~ "{" ~ match_arm* ~ "}" }
match_arm = { match_pattern ~ "=>" ~ (statement | ("{" ~ statement* ~ "}")) }
match_pattern = {
    range_pattern
    | literal_pattern
    | wildcard_pattern
}
range_pattern = { expression ~ ".." ~ expression }
literal_pattern = { expression }
wildcard_pattern = { "_" }

// Ailewu (unsafe) block: ailewu { } or unsafe { }
// Yoruba: àìléwu = without danger (ironic - marks dangerous code)
ailewu_stmt = { ailewu_kw ~ "{" ~ statement* ~ "}" }
ailewu_kw = _{ "ailewu" | "àìléwu" | "unsafe" }

// Yield: jowo 1000; or yield 1000;
// Yoruba: jọ̀wọ́ (please/yield) - using jowo for "yielding control"
yield_stmt = { yield_kw ~ expression ~ ";" }
yield_kw = _{ "jowo" | "jọ̀wọ́" | "yield" }

// Try/Catch/Finally: gbiyanju { ... } gba (e) { ... } nipari { ... }
// Yoruba: gbiyanju (try), gba (accept/take/catch), nipari (finally/in conclusion)
try_stmt = { try_kw ~ "{" ~ statement* ~ "}" ~ catch_clause ~ nipari_clause? }
catch_clause = { catch_kw ~ "(" ~ ident ~ ")" ~ "{" ~ statement* ~ "}" }
nipari_clause = { nipari_kw ~ "{" ~ statement* ~ "}" }
try_kw = _{ "gbiyanju" | "gbìyànjú" | "try" }
catch_kw = _{ "gba" | "gbà" | "catch" }
nipari_kw = _{ "nipari" | "nípàrí" | "finally" }

// ═══════════════════════════════════════════════════════════════════════════
// EXPRESSIONS
// ═══════════════════════════════════════════════════════════════════════════

expression = { or_expr }
or_expr = { and_expr ~ (or_op ~ and_expr)* }
and_expr = { not_expr ~ (and_op ~ not_expr)* }
not_expr = { comparison }

comparison = { arith_expr ~ (comp_op ~ arith_expr)* }
arith_expr = { term ~ ((add_op | sub_op) ~ term)* }
term = { factor ~ ((mul_op | div_op | mod_op) ~ factor)* }
// Postfix `?` (error propagation, §12.3) binds tightly to its atom.
factor = { unary_op* ~ atom ~ try_op? }
try_op = { "?" }

atom = {
    odu_call
    | method_call
    | property_access
    | function_call
    | index_access
    | await_expr
    | list_literal
    | map_literal
    | number
    | interpolated_string
    | string
    | boolean
    | nil
    | ident
    | "(" ~ expression ~ ")"
}

// Interpolated string: $"Hello {name}"
interpolated_string = { "$" ~ "\"" ~ (interp_part)* ~ "\"" }
interp_part = { interp_expr | interp_text }
interp_text = @{ ( (!("\"" | "{" | "\\") ~ ANY) | ("\\" ~ ANY) )+ }
interp_expr = { "{" ~ expression ~ "}" }

// Function call: func(args)
function_call = { ident ~ "(" ~ arguments? ~ ")" }

// Method call: obj.method(args) or obj?.method(args)
method_call = { ident ~ chain_op ~ ident ~ "(" ~ arguments? ~ ")" }

// Property access: obj.field or obj?.field
property_access = { ident ~ ( chain_op ~ ident )+ }

// List: [1, 2, 3]
list_literal = { "[" ~ (expression ~ ("," ~ expression)*)? ~ "]" }

// Map: { "key": value }
map_literal = { "{" ~ (map_entry ~ ("," ~ map_entry)*)? ~ "}" }
map_entry = { (string | ident) ~ ":" ~ expression }

// Index: arr[0] or arr?.[0]
index_access = { ident ~ "?."? ~ "[" ~ expression ~ "]" }

// Await: reti expr
await_expr = { await_kw ~ expression }

// Arguments
arguments = { expression ~ ("," ~ expression)* }

// ═══════════════════════════════════════════════════════════════════════════
// OPERATORS
// ═══════════════════════════════════════════════════════════════════════════

add_op = { "+" }
sub_op = { "-" }
mul_op = { "*" }
div_op = { "/" }
mod_op = { "%" }
unary_op = { "+" | "-" | "&" | "*" }

comp_op = { "==" | "!=" | "<=" | ">=" | "<" | ">" }
and_op = { "&&" | "ati" | "and" }
or_op = { "||" | "tabi" | "or" }
not_op = { "!" | "kii" | "not" }
chain_op = { "." | "?." }
optional_chain_op = { "?." }

// ═══════════════════════════════════════════════════════════════════════════
// KEYWORDS (Yoruba + English)
// ═══════════════════════════════════════════════════════════════════════════

import_kw = _{ "iba" | "ìbà" | "import" | "mu" }
from_kw = _{ "lati" | "láti" | "from" }
var_kw = _{ "ayanmo" | "ayanmọ" | "àyànmọ́" | "variable" | "let" | "var" }
odu_kw = _{ "odu" | "odù" | "class" }
ese_kw = _{ "ese" | "ẹsẹ" | "fn" | "function" | "def" }
if_kw = _{ "ti" | "bí" | "if" }
else_kw = _{ "bibẹkọ" | "else" }
while_kw = _{ "nigba" | "while" }
for_kw = _{ "fun" | "for" }
in_kw = _{ "ninu" | "in" }
return_kw = _{ "pada" | "return" | "da" }
ase_kw = _{ "ase" | "àṣẹ" | "end" }
match_kw = _{ "yàn" | "yán" | "match" }
public_mod = { "gbangba" | "public" | "fi" | "export" }
async_mod = { async_kw }
async_kw = _{ "daro" | "async" }
await_kw = _{ "reti" | "await" }

// ═══════════════════════════════════════════════════════════════════════════
// ODÙ DOMAIN NAMES (The 16 Principal)
// ═══════════════════════════════════════════════════════════════════════════

odu_name = @{
    "Ogbe" | "Ogbè" | "sys" | "system" |
    "Oyeku" | "Ọ̀yẹ̀kú" | "exit" |
    "Iwori" | "Ìwòrì" | "time" |
    "Odi" | "Òdí" | "fs" | "io" |
    "Irosu" | "Ìrosù" | "log" | "out" |
    "Owonrin" | "Ọ̀wọ́nrín" | "rand" |
    "Obara" | "Ọ̀bàrà" | "math" | "arithmetic" |
    "Okanran" | "Ọ̀kànràn" | "err" | "debug" |
    "Ogunda" | "Ògúndá" | "vec" | "list" |
    "Osa" | "Ọ̀sá" | "async" | "task" |
    "Ika" | "Ìká" | "str" | "string" |
    "Oturupon" | "Òtúúrúpọ̀n" | "inv" | "calc" | "inverse" |
    "Otura" | "Òtúrá" | "net" | "http" |
    "Irete" | "Ìrẹtẹ̀" | "hash" | "crypto" |
    "Ose" | "Ọ̀ṣẹ́" | "ui" | "gui" | "draw" |
    "Ofun" | "Òfún" | "meta" | "perm" |
    // Pseudo-domains
    "Coop" | "Àjọṣe" | "ffi" | "bridge" |
    "Opele" | "Ọpẹlẹ" | "Oracle" |
    // Infrastructure
    "Sys" | "System" |
    "Cpu" | "Gpu" |
    "Storage" | "Store" | "Db" |
    "Ohun" | "Audio" |
    "Fidio" | "Video" |
    // Stacks
    "Backend" | "Frontend" |
    "Fullstack" | "Fusion" |
    "Game" | "GameDev" |
    "Ml" | "Ai" |
    "Iot" | "Embedded"
}

// ═══════════════════════════════════════════════════════════════════════════
// TERMINALS
// ═══════════════════════════════════════════════════════════════════════════

ident = @{ (ASCII_ALPHA | "_" | '\u{0080}'..'\u{FFFF}') ~ (ASCII_ALPHANUMERIC | "_" | '\u{0080}'..'\u{FFFF}')* }
number = @{
    ("0x" ~ (ASCII_HEX_DIGIT | "_")+)
    | ("0b" ~ (ASCII_BIN_DIGIT | "_")+)
    | (ASCII_DIGIT ~ (ASCII_DIGIT | "_")* ~ ("." ~ ASCII_DIGIT ~ (ASCII_DIGIT | "_")*)?)
}
string = @{
    "\"" ~ ( (!("\"" | "\\") ~ ANY) | ("\\" ~ ANY) )* ~ "\""
    | "'" ~ ( (!("'" | "\\") ~ ANY) | ("\\" ~ ANY) )* ~ "'"
}
boolean = { "true" | "false" | "otito" | "iro" }
nil = { "ofo" | "null" | "nil" }

// Comments - multiple styles supported
COMMENT = _{
    block_comment
    | doc_comment
    | line_comment_slash
    | line_comment_hash
}

doc_comment = @{ "///" ~ (!NEWLINE ~ ANY)* }
block_comment = @{ "/*" ~ (!"*/" ~ ANY)* ~ "*/" }
line_comment_slash = @{ "//" ~ (!NEWLINE ~ ANY)* }
line_comment_hash = @{ "#" ~ (!NEWLINE ~ ANY)* }

WHITESPACE = _{ " " | "\t" | "\r" | "\n" }
